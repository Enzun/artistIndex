{
  "name": "artist-index",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":        "next dev --turbopack",
    "build":      "next build",
    "start":      "next start",
    "fetch":      "tsx --env-file=.env scripts/fetch_views.ts",
    "calc":       "tsx --env-file=.env scripts/calc_index.ts",
